# ── Required ──────────────────────────────────────────────────────────────────
# OpenRouter API key (get one at https://openrouter.ai)
OPENROUTER_API_KEY=

# ── LLM ───────────────────────────────────────────────────────────────────────
# Override the default model (default: openai/gpt-4o-mini)
# OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Vector store ──────────────────────────────────────────────────────────────
# ChromaDB persistence directory (default: ./backend/vectorstore)
# CHROMA_PERSIST_DIR=./vectorstore

# ── Sessions ──────────────────────────────────────────────────────────────────
# Redis URL for persistent, horizontally-scalable session storage.
# Omit to use the in-memory fallback (sessions lost on restart).
# REDIS_URL=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Default: http://localhost:3000 (safe for local dev).
# ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Set RATE_LIMIT_ENABLED=false to disable (useful in test environments).
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_CHAT=60/minute
# RATE_LIMIT_RESET=20/minute

# ── Front-desk integrations (all optional) ────────────────────────────────────
# Fire only on an explicit "accept" of a visit estimate. Leave unset for demo
# mode: each integration then reports dry_run and never touches the network.

# Airtable CRM lead capture.
# API docs: https://airtable.com/developers/web/api/create-records
# Personal access token: https://airtable.com/create/tokens
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=
# AIRTABLE_TABLE_NAME=Leads

# Cal.com appointment booking.
# API docs: https://cal.com/docs/api-reference/v2/bookings/create-a-booking
# CALCOM_API_KEY=
# CALCOM_EVENT_TYPE_ID=
# IANA timezone reported for the booking attendee (default: UTC)
# CLINIC_TIMEZONE=UTC
# Attendee email used for phone-only (emergency) bookings, which collect no
# email — Cal.com v2 requires one. Point this at an inbox the front desk reads.
# CALCOM_FALLBACK_EMAIL=front-desk@ivory-dental.example

# Resend confirmation email.
# API docs: https://resend.com/docs/api-reference/emails/send-email
# RESEND_API_KEY=
# RESEND_FROM=Ivory <onboarding@resend.dev>
